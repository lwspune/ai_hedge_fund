# Copy to dashboard/.env. The anon key is read-only (RLS allows SELECT only) and ships
# in the client bundle by design — safe to expose. For Vercel, set these in the project's
# Environment Variables instead of committing them.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
